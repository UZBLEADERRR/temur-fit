# Master (super-admin boshqaruv) bot tokeni. @BotFather dan oling.
MASTER_BOT_TOKEN="123456:ABC-MASTER-BOT-TOKEN"

# Super-admin Telegram ID — faqat shu odam super panelga kira oladi
SUPER_ADMIN_ID="1669809576"

# WebApp (React panel) joylashgan ochiq HTTPS URL (bu xizmatning o'zi)
# Masalan Railway domeni: https://temur-fit-saas.up.railway.app
WEBAPP_URL="https://your-deployment-url"

# Server porti (Railway avtomatik beradi)
PORT=3000
