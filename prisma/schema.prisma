generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================================================================
// Temur.fit SAAS — Multi-tenant
// Har bir Tenant = bitta bot + bitta guruh. Super-admin yangi tenant
// (bot tokeni + guruh id) qo'shib, cheksiz klon yaratishi mumkin.
// ====================================================================

model Tenant {
  id              Int      @id @default(autoincrement())
  botToken        String   @unique
  botUsername     String?  // @getMe orqali aniqlanadi
  groupId         String?  // boshqariladigan guruh chat id
  name            String   @default("Temur.fit")
  ownerTelegramId String?  // guruh admini (panelga kira oladi)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  users    User[]
  settings Settings?
}

model User {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  telegramId String
  name       String
  latitude   Float?
  longitude  Float?
  timezone   String   @default("Asia/Tashkent")
  role       String   @default("user") // "admin" yoki "user"
  createdAt  DateTime @default(now())

  mealRecords       MealRecord[]
  mentions          Mention[]
  reminderOverrides ReminderOverride[]

  @@unique([tenantId, telegramId])
}

model MealRecord {
  id       Int      @id @default(autoincrement())
  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date     String // ISO date string local to user, e.g., "2026-04-02"
  mealType String // "nonushta", "abed", "kechki_ovqat"
  timeSent DateTime // UTC timestamp when they sent the photo
  status   String // "on_time", "late"

  @@unique([userId, date, mealType])
}

model Mention {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealType  String // "nonushta", "abed", "kechki_ovqat"
  date      String // Local date e.g. "2026-04-02"
  messageId Int // Telegram message ID to delete
  updatedAt DateTime @updatedAt
  count     Int      @default(1)

  @@unique([userId, mealType, date])
}

model Settings {
  id                 Int     @id @default(autoincrement())
  tenantId           Int     @unique
  tenant             Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId            String?
  breakfastTime      String  @default("08:00")
  lunchTime          String  @default("12:00")
  dinnerTime         String  @default("18:00")
  reminderInterval   Int     @default(60)
  pinnedMessageId    Int?
  lastDailyUpdateStr String?
  breakfastWords     String  @default("nonushta,#nonushta")
  lunchWords         String  @default("abed,#abed,tushlik,#tushlik")
  dinnerWords        String  @default("kechki_ovqat,#kechki_ovqat,kechki,#kechki")
  maxReminders       Int     @default(3)
}

model ReminderOverride {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealType  String // "nonushta", "abed", "kechki_ovqat"
  muted     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, mealType])
}
